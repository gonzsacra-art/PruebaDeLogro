<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="1100.0" style="-fx-background-color: #F4F6F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucv.lab12.controller.VideojuegoController">
    <children>

        <HBox alignment="CENTER_LEFT" layoutX="0.0" layoutY="0.0" prefHeight="70.0" prefWidth="1100.0" style="-fx-background-color: #1A5276;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="MÓDULO DE GESTIÓN DE VIDEOJUEGOS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets left="30.0" />
            </padding>
        </HBox>

        <VBox layoutY="70.0" prefWidth="350.0" spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="70.0">
            <padding>
                <Insets bottom="20.0" top="20.0" left="25.0" right="25.0" />
            </padding>
            <children>
                <Label text="Datos del Videojuego" textFill="#2C3E50">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <Label text="Nombre del Juego:" textFill="#566573" />
                <TextField fx:id="txtNombre" prefHeight="30.0" style="-fx-background-radius: 5;" />

                <Label text="Consola / Plataforma:" textFill="#566573" />
                <TextField fx:id="txtConsola" prefHeight="30.0" style="-fx-background-radius: 5;" />

                <Label text="Género:" textFill="#566573" />
                <TextField fx:id="txtGenero" prefHeight="30.0" style="-fx-background-radius: 5;" />

                <Label text="Clasificación:" textFill="#566573" />
                <TextField fx:id="txtClasificacion" prefHeight="30.0" style="-fx-background-radius: 5;" />

                <Label text="Descripción:" textFill="#566573" />
                <TextArea fx:id="txtDescripcion" prefHeight="70.0" wrapText="true" style="-fx-background-radius: 5;" />

                <HBox spacing="10.0">
                    <children>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="ID Desarrollador:" textFill="#566573" />
                                <TextField fx:id="txtIdDesarrollador" prefHeight="30.0" style="-fx-background-radius: 5;" />
                            </children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="ID Distribuidor:" textFill="#566573" />
                                <TextField fx:id="txtIdDistribuidor" prefHeight="30.0" style="-fx-background-radius: 5;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10.0">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                    <children>
                        <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardarVideojuego" prefHeight="35.0" prefWidth="300.0" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Guardar Registro">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnLimpiar" mnemonicParsing="false" onAction="#limpiarFormulario" prefHeight="35.0" prefWidth="300.0" style="-fx-background-color: #7F8C8D; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Limpiar Campos" />
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox layoutX="350.0" layoutY="70.0" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="350.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
            <padding>
                <Insets bottom="20.0" top="20.0" left="20.0" right="20.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="40.0">
                    <children>
                        <Label text="Lista de Videojuegos Registrados" textFill="#2C3E50">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Label>
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#regresarAlMenu" prefHeight="30.0" style="-fx-background-color: #C0392B; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="← Volver al Menú" />
                    </children>
                </HBox>

                <TableView fx:id="tblVideojuegos" prefHeight="430.0" style="-fx-background-radius: 5; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="180.0" text="Nombre" />
                        <TableColumn fx:id="colConsola" prefWidth="120.0" text="Consola" />
                        <TableColumn fx:id="colGenero" prefWidth="110.0" text="Género" />
                        <TableColumn fx:id="colClasificacion" prefWidth="100.0" text="Clasif." />
                        <TableColumn fx:id="colDescripcion" prefWidth="180.0" text="Descripción" />
                        <TableColumn fx:id="colIdDesarrollador" prefWidth="85.0" text="ID Desarr." />
                        <TableColumn fx:id="colIdDistribuidor" prefWidth="85.0" text="ID Distrib." />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>

    </children>
</AnchorPane>