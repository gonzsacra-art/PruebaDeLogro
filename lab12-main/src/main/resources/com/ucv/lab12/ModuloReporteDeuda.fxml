<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="550.0" prefWidth="620.0" spacing="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.ModuloReporteDeudaController">
    <children>

        <VBox spacing="2.0">
            <children>
                <Label text="Consulta y Reporte de Deudas" textFill="#1e3a8a">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Label text="Filtre los registros para auditoría y toma de decisiones financieras." textFill="#64748b" />
            </children>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 8;">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Buscar por DNI u Apellidos" textFill="#475569" style="-fx-font-weight: bold;" />
                        <TextField fx:id="txtCriterioBusqueda" promptText="Ingrese DNI o Apellido..." style="-fx-padding: 8;" />
                    </children>
                </VBox>
                <VBox spacing="4.0" prefWidth="180.0">
                    <children>
                        <Label text="Estado de Deuda" textFill="#475569" style="-fx-font-weight: bold;" />
                        <ComboBox fx:id="cmbFiltroEstado" prefWidth="9999.0" promptText="Todos" style="-fx-padding: 5;" />
                    </children>
                </VBox>
                <Button fx:id="btnFiltrar" mnemonicParsing="false" onAction="#onFiltrarDeudas" text="🔍 Buscar"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;">
                    <HBox.margin>
                        <Insets top="20.0" />
                    </HBox.margin>
                </Button>
            </children>
        </HBox>

        <TableView fx:id="tblReportes" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" style="-fx-background-radius: 6;">
            <columns>
                <TableColumn fx:id="colDni" prefWidth="90.0" text="DNI" />
                <TableColumn fx:id="colDocente" prefWidth="180.0" text="Docente" />
                <TableColumn fx:id="colResolucion" prefWidth="110.0" text="N° Resolución" />
                <TableColumn fx:id="colMontoOriginal" prefWidth="110.0" text="M. Original" />
                <TableColumn fx:id="colSaldoPendiente" prefWidth="110.0" text="Saldo Pendiente" />
                <TableColumn fx:id="colEstado" prefWidth="90.0" text="Estado" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button fx:id="btnExportarExcel" mnemonicParsing="false" onAction="#onExportarExcel" text="📊 Exportar Excel"
                        style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-padding: 10 15; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" />
            </children>
        </HBox>

    </children>
</VBox>